{
  "$schema": "https://json.schemastore.org/deployment.json",
  "name": "CODEBYTE Website",
  "version": "1.0.0",
  "description": "Digital Innovation Agency - Full-service technology powerhouse",
  "scripts": {
    "build": "npm run build",
    "start": "npx serve -s dist -l $PORT"
  },
  "build": {
    "command": "npm run build",
    "output": "dist",
    "environment": {
      "NODE_VERSION": "18.x"
    }
  },
  "routes": [
    {
      "route": "/*",
      "serve": "/index.html"
    }
  ]
}
